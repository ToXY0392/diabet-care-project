<%# Layout principal : structure HTML, navbar, flash messages.
    La navbar affiche des liens différents selon logged_in? %>
<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Diabet Care Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Diabet Care Project">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Bootstrap 5 %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%# Navbar : liens principaux + menu utilisateur (connecté) ou login/signup (non connecté) %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
      <div class="container">
        <%= link_to "DiabetCare", root_path, class: "navbar-brand" %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <% if logged_in? %>
            <ul class="navbar-nav me-auto">
              <li class="nav-item"><%= link_to "Tableau de bord", dashboard_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "Glycémies", glucose_readings_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "Repas", meals_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "Objectifs", target_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "Rapports", reports_path, class: "nav-link" %></li>
              <li class="nav-item">
                <% if current_user.dexcom_access_token.present? %>
                  <%= button_to "Dexcom ✓", dexcom_sync_path, method: :post, class: "nav-link btn btn-link border-0 p-0", form: { class: "d-inline" } %>
                <% else %>
                  <%= link_to "Dexcom", dexcom_connect_path, class: "nav-link" %>
                <% end %>
              </li>
            </ul>
            <ul class="navbar-nav">
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><%= current_user.email %></a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><%= link_to "Paramètres", target_path, class: "dropdown-item" %></li>
                  <li><%= link_to "Données personnelles", data_export_path, class: "dropdown-item" %></li>
                  <li><%= link_to "Confidentialité", privacy_path, class: "dropdown-item" %></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><%= button_to "Déconnexion", logout_path, method: :delete, class: "dropdown-item" %></li>
                </ul>
              </li>
            </ul>
          <% else %>
            <ul class="navbar-nav ms-auto">
              <li class="nav-item"><%= link_to "Se connecter", login_path, class: "nav-link" %></li>
              <li class="nav-item"><%= link_to "S'inscrire", signup_path, class: "btn btn-light btn-sm ms-2" %></li>
            </ul>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="<%= 'container py-4' if logged_in? %>">
      <% if flash[:notice] %><div class="alert alert-success"><%= flash[:notice] %></div><% end %>
      <% if flash[:alert] %><div class="alert alert-danger"><%= flash[:alert] %></div><% end %>
      <%= yield %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartkick"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  </body>
</html>

<% content_for :title, "Modifier entree journal | DiabetCare" %>

<main class="content-page">
  <section class="content-header">
    <div>
      <p class="eyebrow">Journal patient</p>
      <h1>Modifier l'entree</h1>
      <p class="hero-copy">Ajustez les informations de contexte pour vos analyses futures.</p>
    </div>
  </section>

  <section class="overview-strip">
    <article class="metric-chip">
      <span>Action</span>
      <strong>Edition journal</strong>
    </article>
    <article class="metric-chip">
      <span>Objectif</span>
      <strong>Contexte exploitable</strong>
    </article>
  </section>

  <section class="panel form-panel">
    <%= render "form", journal_entry: @journal_entry %>
  </section>
</main>

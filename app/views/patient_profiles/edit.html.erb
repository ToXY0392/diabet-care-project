<% content_for :title, "Modifier mon profil sante | DiabetCare" %>

<main class="content-page">
  <section class="content-header">
    <div>
      <p class="eyebrow">Profil patient</p>
      <h1>Modifier mon profil sante</h1>
      <p class="hero-copy">Ces seuils sont utilises par les alertes et les indicateurs du dashboard.</p>
    </div>
  </section>

  <section class="overview-strip">
    <article class="metric-chip">
      <span>Action</span>
      <strong>Edition profil</strong>
    </article>
    <article class="metric-chip">
      <span>Usage</span>
      <strong>Seuils et notifications</strong>
    </article>
  </section>

  <section class="panel form-panel">
    <%= render "form", patient_profile: @patient_profile %>
  </section>
</main>

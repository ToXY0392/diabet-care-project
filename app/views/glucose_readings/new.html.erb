<% content_for :title, "Nouvelle mesure | DiabetCare" %>

<main class="content-page">
  <section class="content-header">
    <div>
      <p class="eyebrow">Creation</p>
      <h1>Nouvelle mesure glycemique</h1>
      <p class="hero-copy">Ajoutez une nouvelle mesure pour mettre a jour le dashboard.</p>
    </div>
  </section>

  <section class="overview-strip">
    <article class="metric-chip">
      <span>Action</span>
      <strong>Nouvelle mesure</strong>
    </article>
    <article class="metric-chip">
      <span>Impact</span>
      <strong>Dashboard mis a jour</strong>
    </article>
  </section>

  <section class="panel form-panel">
    <%= render "form", glucose_reading: @glucose_reading %>
  </section>
</main>

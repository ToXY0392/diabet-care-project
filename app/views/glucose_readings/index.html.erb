<%# Liste des glycémies : tableau + boutons modifier/supprimer %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Glycémies</h2>
  <%= link_to "Nouvelle mesure", new_glucose_reading_path, class: "btn btn-primary" %>
</div>

<% if @glucose_readings.any? %>
  <div class="table-responsive">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Date / Heure</th>
          <th>Valeur (mg/dL)</th>
          <th>Tendance</th>
          <th>Source</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @glucose_readings.each do |r| %>
          <tr>
            <td><%= l(r.recorded_at, format: :short) %></td>
            <td><strong><%= r.value %></strong></td>
            <td><%= r.trend || "-" %></td>
            <td><span class="badge bg-<%= r.source == 'dexcom' ? 'info' : 'secondary' %>"><%= r.source %></span></td>
            <td>
              <%= link_to "Modifier", edit_glucose_reading_path(r), class: "btn btn-sm btn-outline-primary" %>
              <%= button_to "Suppr.", glucose_reading_path(r), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { turbo_confirm: "Supprimer ?" } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">Aucune glycémie enregistrée. <%= link_to "Ajouter une mesure", new_glucose_reading_path %></p>
<% end %>

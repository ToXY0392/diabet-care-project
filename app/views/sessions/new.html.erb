<div class="container py-5" style="max-width: 400px;">
  <h2 class="mb-4">Connexion</h2>

  <%= form_with url: login_path, method: :post, local: true, data: { turbo: false } do |f| %>
    <div class="mb-3">
      <%= label_tag :email, "Email", class: "form-label" %>
      <%= email_field_tag :email, params[:email], class: "form-control", required: true, autofocus: true %>
    </div>

    <div class="mb-3">
      <%= label_tag :password, "Mot de passe", class: "form-label" %>
      <%= password_field_tag :password, nil, class: "form-control", required: true %>
    </div>

    <div class="mb-3">
      <%= submit_tag "Se connecter", class: "btn btn-primary w-100" %>
    </div>
  <% end %>

  <p class="text-center text-muted">
    Pas encore de compte ? <%= link_to "S'inscrire", signup_path %>
  </p>
</div>

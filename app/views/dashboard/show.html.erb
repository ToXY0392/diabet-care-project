<%# Tableau de bord : résumé (compteurs glycémies, repas) + accès Dexcom + liens rapides %>
<div class="py-4">
  <h2 class="mb-4">Tableau de bord</h2>

  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Glycémies</h5>
          <p class="card-text"><%= current_user.glucose_readings.count %> mesures</p>
          <%= link_to "Voir / Ajouter", glucose_readings_path, class: "btn btn-sm btn-primary" %>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Repas</h5>
          <p class="card-text"><%= current_user.meals.count %> repas</p>
          <%= link_to "Voir / Ajouter", meals_path, class: "btn btn-sm btn-primary" %>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Dexcom</h5>
          <% if current_user.dexcom_access_token.present? %>
            <p class="card-text text-success">Connecté</p>
            <%= button_to "Synchroniser", dexcom_sync_path, method: :post, class: "btn btn-sm btn-outline-primary" %>
          <% else %>
            <p class="card-text text-muted">Non connecté</p>
            <%= link_to "Connecter Dexcom", dexcom_connect_path, class: "btn btn-sm btn-primary" %>
            <%= link_to "Diagnostic", dexcom_check_path, class: "btn btn-sm btn-outline-secondary ms-1" if Rails.env.development? %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h5 class="card-title">Accès rapide</h5>
      <%= link_to "Objectifs", target_path, class: "btn btn-outline-secondary me-2" %>
      <%= link_to "Rapports & graphiques", reports_path, class: "btn btn-outline-secondary me-2" %>
      <%= link_to "Données personnelles (RGPD)", data_export_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>

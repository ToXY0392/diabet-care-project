<% content_for :title, "Nouveau programme traitement | DiabetCare" %>

<main class="content-page">
  <section class="content-header">
    <div>
      <p class="eyebrow">Traitements</p>
      <h1>Nouveau programme recurrent</h1>
      <p class="hero-copy">Configurez une ou plusieurs heures de prise et les jours actifs.</p>
    </div>
  </section>

  <section class="overview-strip">
    <article class="metric-chip">
      <span>Action</span>
      <strong>Nouveau programme</strong>
    </article>
    <article class="metric-chip">
      <span>Fenetre</span>
      <strong>Occurrences 14 jours</strong>
    </article>
  </section>

  <section class="panel form-panel">
    <%= render "form", medication_schedule: @medication_schedule %>
  </section>
</main>

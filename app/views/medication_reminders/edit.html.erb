<% content_for :title, "Modifier traitement | DiabetCare" %>

<main class="content-page">
  <section class="content-header">
    <div>
      <p class="eyebrow">Edition</p>
      <h1>Modifier le rappel de traitement</h1>
      <p class="hero-copy">Ajustez l'heure, le dosage ou les instructions de cette prise.</p>
    </div>
  </section>

  <section class="overview-strip">
    <article class="metric-chip">
      <span>Action</span>
      <strong>Edition prise</strong>
    </article>
    <article class="metric-chip">
      <span>Objectif</span>
      <strong>Historique precis</strong>
    </article>
  </section>

  <section class="panel form-panel">
    <%= render "form", medication_reminder: @medication_reminder %>
  </section>
</main>

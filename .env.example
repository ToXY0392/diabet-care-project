# Dexcom API (https://developer.dexcom.com/)
# Créer une application et configurer la redirect URI sur le portail Dexcom.
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=

# Redirect URI (optionnel) : si défini, remplace l'URL générée automatiquement.
# Doit correspondre EXACTEMENT à l'URI enregistrée sur developer.dexcom.com
# Ex : http://localhost:3000/dexcom/callback ou http://127.0.0.1:3001/dexcom/callback
# DEXCOM_REDIRECT_URI=

# Utiliser le sandbox Dexcom pour les tests (true/false)
DEXCOM_SANDBOX=true
